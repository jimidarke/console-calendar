# ═══════════════════════════════════════════════════════════════════════════════
# Console Calendar - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   chmod 600 .env
# ═══════════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────────
# HOME ASSISTANT CONNECTION
# ───────────────────────────────────────────────────────────────────────────────

# Home Assistant server URL (include port if not 80/443)
# Examples:
#   http://192.168.1.40:8123
#   http://homeassistant.local:8123
#   https://ha.yourdomain.com
HOMEASSISTANT_URL=http://192.168.1.40:8123

# Long-lived access token from Home Assistant
# Generate at: Profile -> Security -> Long-Lived Access Tokens -> Create Token
HOMEASSISTANT_LONG_LIVE_TOKEN=your_token_here

# ───────────────────────────────────────────────────────────────────────────────
# CALENDAR CONFIGURATION
# ───────────────────────────────────────────────────────────────────────────────

# Calendar entity ID to display
# Run `python3 ha_list_calendars.py` to see available calendars
# Examples:
#   calendar.family
#   calendar.google_calendar
#   calendar.work
HA_CALENDAR_ENTITY=calendar.family

# Display title shown in header (uppercase recommended)
HA_CALENDAR_TITLE=FAMILY CALENDAR

# Number of days ahead to show (1-30)
HA_DAYS_AHEAD=7

# ───────────────────────────────────────────────────────────────────────────────
# DISPLAY OPTIONS
# ───────────────────────────────────────────────────────────────────────────────

# Use Unicode symbols (true/false)
# Set to false for terminals without Unicode support
HA_USE_UNICODE=true

# Time format: 12 or 24
HA_TIME_FORMAT=12

# Date format (strftime format)
# Examples:
#   %b %d, %Y     -> Jan 08, 2026
#   %Y-%m-%d      -> 2026-01-08
#   %d/%m/%Y      -> 08/01/2026
HA_DATE_FORMAT=%b %d, %Y

# Show event locations (true/false)
HA_SHOW_LOCATIONS=true

# Show event descriptions (true/false)
HA_SHOW_DESCRIPTIONS=false

# Timezone for display (IANA timezone name)
# Examples: America/Edmonton, America/New_York, Europe/London, UTC
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
HA_TIMEZONE=America/Edmonton

# ───────────────────────────────────────────────────────────────────────────────
# VIEW SETTINGS
# ───────────────────────────────────────────────────────────────────────────────

# Default view on startup: agenda, month, or week
# Users can switch views at runtime with keyboard shortcuts (a/m/w)
HA_DEFAULT_VIEW=agenda

# Week start day for month/week views: monday or sunday
HA_WEEK_START=monday

# Hour range for week view (24-hour format)
# Events outside this range won't be displayed in week view
HA_WEEK_HOUR_START=7
HA_WEEK_HOUR_END=21

# ───────────────────────────────────────────────────────────────────────────────
# REFRESH INTERVALS (seconds)
# ───────────────────────────────────────────────────────────────────────────────

# How often to fetch new data from Home Assistant API
# Lower = more responsive, but more API calls
# Recommended: 60-300
HA_API_REFRESH_INTERVAL=60

# How often to redraw the screen (for clock updates)
# Recommended: 1
HA_SCREEN_REFRESH_INTERVAL=1

# ───────────────────────────────────────────────────────────────────────────────
# KIOSK MODE SETTINGS (used by setup_kiosk.sh)
# ───────────────────────────────────────────────────────────────────────────────

# Linux user to run kiosk as
KIOSK_USER=kiosk

# TTY device for kiosk display
KIOSK_TTY=tty1

# Auto-restart on crash (true/false)
KIOSK_AUTO_RESTART=true

# Restart delay in seconds after crash/exit
KIOSK_RESTART_DELAY=5
