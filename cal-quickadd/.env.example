# Gemini Flash API key (from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key

# Google Calendar ID (usually your email, or a specific calendar ID)
# Find at: Google Calendar > Settings > Calendar ID
GOOGLE_CALENDAR_ID=your-email@gmail.com

# Path to Google OAuth credentials and token
GOOGLE_CREDENTIALS_PATH=/config/credentials.json
GOOGLE_TOKEN_PATH=/config/token.json

# Family member calendar mapping (JSON)
# Maps names to Google Calendar IDs. Unmatched names use GOOGLE_CALENDAR_ID.
# Example: {"jonnie": "family123@group.calendar.google.com", "jimi": "jimi@gmail.com"}
FAMILY_CALENDARS={}

# Family member names (comma-separated, for AI parser context)
FAMILY_MEMBERS=jimi,wife,jonnie

# Timezone
TIMEZONE=America/Edmonton
